      <column caption='Risk Level' datatype='string' name='[Calculation_1015184091090944]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [magnitude] &gt;= [Parameters].[Parameter 1] THEN &quot;High Risk&quot;&#13;&#10;ELSE &quot;Low Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Tsunami Label' datatype='string' name='[Calculation_1015184094855169]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tsunami] = 1 THEN &quot;Tsunami&quot;&#13;&#10;ELSE &quot;No Tsunami&quot;&#13;&#10;END' />
      </column>
      <column caption='Region' datatype='string' name='[Calculation_1015184101302275]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [latitude] &gt; 30 THEN &quot;North&quot;&#13;&#10;ELSEIF [latitude] &lt; -30 THEN &quot;South&quot;&#13;&#10;ELSE &quot;Equator&quot;&#13;&#10;END' />
      </column>
      <column caption='Event_info' datatype='string' name='[Calculation_1015184110239748]' role='dimension' type='nominal'>
